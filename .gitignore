# Machine-specific MCP registration — regenerated by setup.bat on each machine
.mcp.json
.claude/settings.local.json

# Python cache
__pycache__/
*.pyc
*.pyo

# Virtual environments
venv/
.venv/
env/

# Hayabusa binary — downloaded by download_hayabusa.py, not committed (~70 MB, platform-specific)
hayabusa/

# ATT&CK technique cache — regenerated by download_attack_data.py
mappings/attck_techniques.json

# Raw rule-search scratch data, not used by the server
credential_access_rules.json
